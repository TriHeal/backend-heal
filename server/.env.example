#Frontend: http://localhost:3000
#Backend:  http://localhost:3003
#Swagger:  http://localhost:3003/api

PORT=3003
FRONTEND_ORIGIN=http://localhost:3001

# Firebase project
FIREBASE_PROJECT_ID=tri-heal-dev-d9484
GOOGLE_CLOUD_PROJECT=tri-heal-dev-d9484
GCLOUD_PROJECT=tri-heal-dev-d9484
FIREBASE_DATABASE_URL=https://tri-heal-dev-d9484-default-rtdb.europe-west1.firebasedatabase.app

# Firebase Web API key
# Used by backend login to verify T.Z + password via Firebase Auth REST API.
# Get it from: Firebase Console → Project settings → General → Web app → apiKey
FIREBASE_WEB_API_KEY=

# Auth ID hash secret
# Used to convert Israeli T.Z into internal Firebase Auth email:
# T.Z + secret → HMAC-SHA256 → <hash>@auth.triheal.local
# Must be EXACTLY the same in local .env and Render, or login will return 401.
# Do not reuse the full FIREBASE_WEB_API_KEY as this secret unless that is
# intentionally how users were provisioned.
AUTH_ID_HASH_SECRET=

# Local Firebase Admin credentials
# Generate from: Firebase Console → Project settings → Service accounts → Generate new private key
# Save as: backend-heal/server/service-account.json
# Do not commit service-account.json.
GOOGLE_APPLICATION_CREDENTIALS=./service-account.json

# Production / Render: paste the full service-account JSON as a single-line env var.
# Prefer this over Application Default Credentials on hosted environments.
# FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"tri-heal-dev-d9484",...}

# Optional alternative to FIREBASE_SERVICE_ACCOUNT (all three required together):
# FIREBASE_CLIENT_EMAIL=
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Optional: enables GET /health/firebase when request includes
# header x-diagnostics-token: <same value>
# DIAGNOSTICS_TOKEN=

# Parent invitation email settings
# Resend API key for sending emails.
RESEND_API_KEY=
# The email address used as the sender for parent invite emails.
PARENT_INVITE_FROM_EMAIL=no-reply@example.com
# Base URL where parents activate their invitation.
PARENT_INVITE_BASE_URL=http://localhost:3000
